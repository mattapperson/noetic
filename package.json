{
  "name": "noetic",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.3.11"
  },
  "scripts": {
    "postinstall": "node scripts/patch-sdk.js",
    "test": "bun --cwd packages/core run test && bun --cwd packages/eval run test",
    "test:coverage": "bun --cwd packages/core run test:coverage && bun --cwd packages/eval run test:coverage",
    "test:ci": "bun --cwd packages/core run test:ci && bun --cwd packages/eval run test:ci",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --fix .",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "check:exports": "bun scripts/check-export-tags.ts"
  },
  "dependencies": {
    "@openrouter/agent": "0.3.1",
    "@openrouter/sdk": "0.12.0"
  },
  "patchedDependencies": {
    "@openrouter/agent@0.3.1": "patches/@openrouter%2Fagent@0.3.1.patch"
  }
}
