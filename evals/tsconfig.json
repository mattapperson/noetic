{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "bun-types"
    ],
    "customConditions": [
      "bun"
    ]
  },
  "include": [
    "longmem",
    "slopcodebench/*.ts"
  ]
}