# LongMemEval datasets are large (oracle ~15 MB, s ~278 MB, m ~2.75 GB).
# They are downloaded on demand via `bun evals/longmem/download.ts`.
longmem/data/*.json

# SlopCodeBench: the vendored Python benchmark clone, its deps, the wired
# problem links, and run outputs are all generated on demand via
# `bun evals/slopcodebench/setup.ts`.
slopcodebench/vendor/
slopcodebench/problems-local/
slopcodebench/outputs/
__pycache__/
