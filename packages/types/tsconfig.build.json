{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false,
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "test/**/*.ts"]
}
