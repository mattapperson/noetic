{
  "name": "@noetic-tools/platform-node",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@noetic-tools/core": "workspace:*",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@struktoai/mirage-node": "0.0.1"
  },
  "peerDependenciesMeta": {
    "@struktoai/mirage-node": {
      "optional": true
    }
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "test:ci": "bun test --coverage --coverage-reporter=lcov",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --fix ."
  }
}
