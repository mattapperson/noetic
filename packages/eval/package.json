{
  "name": "@noetic/eval",
  "version": "0.1.0",
  "type": "module",
  "description": "Eval framework for Noetic agents: the describe/it/scorer suite runner, built-in and custom scorers, regression baselines, and GEPA-backed prompt optimization.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattapperson/noetic.git",
    "directory": "packages/eval"
  },
  "homepage": "https://github.com/mattapperson/noetic#readme",
  "bugs": {
    "url": "https://github.com/mattapperson/noetic/issues"
  },
  "keywords": [
    "noetic",
    "agents",
    "eval",
    "evaluation",
    "scorers",
    "llm"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "noetic-eval": "./dist/cli/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noetic-tools/core": "workspace:*",
    "typescript": "5.9.3",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@ax-llm/ax": ">=0.1.0",
    "@mariozechner/pi-coding-agent": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@ax-llm/ax": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ax-llm/ax": "latest",
    "bun-types": "latest"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.build.json && bun scripts/add-js-extensions.ts",
    "verify:esm": "bun scripts/verify-node-esm.ts",
    "prepublishOnly": "rm -rf dist && bun run build && bun run verify:esm && bun scripts/pin-workspace-deps.ts && bun scripts/strip-dev-conditions.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "test:ci": "bun test --coverage --coverage-reporter=lcov",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --fix .",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format ."
  }
}
