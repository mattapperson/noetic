{
  "name": "@noetic/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "default": "./src/runtime/index.ts"
    }
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.16.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.5.10",
    "autoprefixer": "^10.4.16",
    "bun-types": "latest",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  },
  "peerDependencies": {
    "@noetic/core": "workspace:*"
  },
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=json",
    "test:ci": "bun test --coverage --coverage-reporter=json",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --fix .",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "dev": "next dev -p 3334",
    "build": "next build",
    "start": "next start -p 3334",
    "serve": "bun src/server/index.ts"
  }
}
