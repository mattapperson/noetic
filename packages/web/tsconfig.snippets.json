{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": ["../../node_modules/.bun/bun-types@1.3.14/node_modules/bun-types"],
    "paths": {
      "@noetic-tools/core": ["../core/src/index.ts"],
      "@noetic-tools/core/*": ["../core/src/*"],
      "@noetic-tools/cli": ["./.typecheck-snippets-shims/noetic-cli.d.ts"],
      "@noetic/eval": ["../eval/src/index.ts"]
    }
  },
  "include": [".typecheck-snippets/**/*.ts", ".typecheck-snippets/**/*.tsx"]
}
