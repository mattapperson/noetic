{
  "name": "@noetic/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test:build": "bun run build",
    "test:links": "bunx lychee --offline 'content/**/*.mdx'",
