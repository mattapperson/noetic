  },
  "dependencies": {
    "fumadocs-core": "16.6.17",
    "fumadocs-mdx": "14.2.10",
    "fumadocs-ui": "16.6.17",
    "motion": "12.36.0",
    "next": "16.1.6",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.8",
    "@types/node": "25.5.0",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "postcss": "8.5.4",
    "tailwindcss": "4.1.8",
    "typescript": "5.8.3"
  }
}
