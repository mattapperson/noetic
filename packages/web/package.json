{
  "name": "@noetic/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fumadocs-mdx && next dev --turbopack",
    "build": "fumadocs-mdx && next build",
    "start": "next start",
    "test:build": "bun run build",
    "test:links": "lychee --offline --root-dir content --fallback-extensions mdx 'content/**/*.mdx'",
    "check:docs": "bun scripts/check-docs.ts",
    "gen:doc-preamble": "bun scripts/gen-doc-preamble.ts",
    "sync-tui": "bun scripts/sync-tui.ts",
    "sync-tui:chrome": "bun scripts/sync-tui.ts --chrome-only",
    "sync-tui:check": "bun scripts/sync-tui.ts --check"
  },
  "dependencies": {
    "fumadocs-core": "16.6.17",
    "fumadocs-mdx": "14.2.10",
    "fumadocs-ui": "16.6.17",
    "motion": "12.36.0",
    "next": "16.1.6",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.8",
    "@types/node": "25.5.0",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "kiira": "0.3.0",
    "kiira-core": "0.3.0",
    "postcss": "8.5.4",
    "tailwindcss": "4.1.8",
    "typescript": "5.8.3",
    "zod": "4.3.6"
  }
}
