{
  "$id": "https://noetic.tools/schema/noetic-workflow.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "const": 1
    },
    "root": {
      "$ref": "#/$defs/WorkflowNode"
    }
  },
  "required": [
    "version",
    "root"
  ],
  "additionalProperties": false,
  "title": "WorkflowDocument",
  "description": "A portable, JSON-safe representation of a Noetic step tree.",
  "$defs": {
    "WorkflowNode": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "llm"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "model": {
              "type": "string"
            },
            "instructions": {
              "type": "string"
            },
            "tools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "params": {
              "type": "object",
              "properties": {
                "temperature": {
                  "type": "number",
                  "minimum": 0
                },
                "topP": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "maxTokens": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "stopSequences": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "kind",
            "id",
            "instructions"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "tool"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "toolName": {
              "type": "string",
              "minLength": 1
            },
            "args": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {}
            }
          },
          "required": [
            "kind",
            "id",
            "toolName"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "branch"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "routes": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "match": {
                    "type": "string",
                    "minLength": 1
                  },
                  "target": {
                    "$ref": "#/$defs/WorkflowNode"
                  }
                },
                "required": [
                  "match",
                  "target"
                ],
                "additionalProperties": false
              }
            },
            "default": {
              "$ref": "#/$defs/WorkflowNode"
            }
          },
          "required": [
            "kind",
            "id",
            "routes"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "fork"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "mode": {
              "type": "string",
              "enum": [
                "race",
                "all",
                "settle"
              ]
            },
            "paths": {
              "minItems": 1,
              "type": "array",
              "items": {
                "$ref": "#/$defs/WorkflowNode"
              }
            },
            "merge": {
              "type": "string",
              "enum": [
                "last",
                "first",
                "concat"
              ]
            },
            "concurrency": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "kind",
            "id",
            "mode",
            "paths"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "spawn"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "child": {
              "$ref": "#/$defs/WorkflowNode"
            },
            "timeout": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "required": [
            "kind",
            "id",
            "child"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "provide"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "child": {
              "$ref": "#/$defs/WorkflowNode"
            },
            "layers": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "required": [
            "kind",
            "id",
            "child",
            "layers"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "loop"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "body": {
              "$ref": "#/$defs/WorkflowNode"
            },
            "until": {
              "$ref": "#/$defs/UntilPredicate"
            },
            "maxIterations": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "kind",
            "id",
            "body",
            "until"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "sequence"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "steps": {
              "minItems": 1,
              "type": "array",
              "items": {
                "$ref": "#/$defs/WorkflowNode"
              }
            }
          },
          "required": [
            "kind",
            "id",
            "steps"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "every"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "step": {
              "$ref": "#/$defs/WorkflowNode"
            },
            "ms": {
              "type": "number",
              "minimum": 0
            },
            "onError": {
              "type": "string",
              "enum": [
                "continue",
                "fail"
              ]
            }
          },
          "required": [
            "kind",
            "id",
            "step",
            "ms"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "claude-code"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "prompt": {
              "type": "string",
              "minLength": 1
            },
            "instructions": {
              "type": "string"
            },
            "settings": {
              "type": "object",
              "properties": {
                "model": {
                  "type": "string"
                },
                "permissionMode": {
                  "type": "string",
                  "enum": [
                    "default",
                    "plan",
                    "acceptEdits",
                    "bypassPermissions"
                  ]
                },
                "maxTurns": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "allowedTools": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "extra": {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {}
                }
              },
              "additionalProperties": false
            },
            "session": {
              "type": "object",
              "properties": {
                "reuse": {
                  "type": "string",
                  "minLength": 1
                },
                "onComplete": {
                  "type": "string",
                  "enum": [
                    "stop",
                    "detach",
                    "destroy"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "kind",
            "id",
            "prompt"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "codex"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "prompt": {
              "type": "string",
              "minLength": 1
            },
            "instructions": {
              "type": "string"
            },
            "settings": {
              "type": "object",
              "properties": {
                "model": {
                  "type": "string"
                },
                "permissionMode": {
                  "type": "string",
                  "enum": [
                    "default",
                    "plan",
                    "acceptEdits",
                    "bypassPermissions"
                  ]
                },
                "maxTurns": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "allowedTools": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "extra": {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {}
                }
              },
              "additionalProperties": false
            },
            "session": {
              "type": "object",
              "properties": {
                "reuse": {
                  "type": "string",
                  "minLength": 1
                },
                "onComplete": {
                  "type": "string",
                  "enum": [
                    "stop",
                    "detach",
                    "destroy"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "kind",
            "id",
            "prompt"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "opencode"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "prompt": {
              "type": "string",
              "minLength": 1
            },
            "instructions": {
              "type": "string"
            },
            "settings": {
              "type": "object",
              "properties": {
                "model": {
                  "type": "string"
                },
                "permissionMode": {
                  "type": "string",
                  "enum": [
                    "default",
                    "plan",
                    "acceptEdits",
                    "bypassPermissions"
                  ]
                },
                "maxTurns": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "allowedTools": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "extra": {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {}
                }
              },
              "additionalProperties": false
            },
            "session": {
              "type": "object",
              "properties": {
                "reuse": {
                  "type": "string",
                  "minLength": 1
                },
                "onComplete": {
                  "type": "string",
                  "enum": [
                    "stop",
                    "detach",
                    "destroy"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "kind",
            "id",
            "prompt"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "pi"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "prompt": {
              "type": "string",
              "minLength": 1
            },
            "instructions": {
              "type": "string"
            },
            "settings": {
              "type": "object",
              "properties": {
                "model": {
                  "type": "string"
                },
                "permissionMode": {
                  "type": "string",
                  "enum": [
                    "default",
                    "plan",
                    "acceptEdits",
                    "bypassPermissions"
                  ]
                },
                "maxTurns": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "allowedTools": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "extra": {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {}
                }
              },
              "additionalProperties": false
            },
            "session": {
              "type": "object",
              "properties": {
                "reuse": {
                  "type": "string",
                  "minLength": 1
                },
                "onComplete": {
                  "type": "string",
                  "enum": [
                    "stop",
                    "detach",
                    "destroy"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "kind",
            "id",
            "prompt"
          ],
          "additionalProperties": false
        }
      ],
      "title": "WorkflowNode"
    },
    "UntilPredicate": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "maxSteps"
            },
            "n": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "kind",
            "n"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "maxCost"
            },
            "usd": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "required": [
            "kind",
            "usd"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "maxDuration"
            },
            "ms": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "required": [
            "kind",
            "ms"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "noToolCalls"
            }
          },
          "required": [
            "kind"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "outputContains"
            },
            "marker": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "marker"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "outputEquals"
            },
            "sentinel": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "sentinel"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "converged"
            },
            "threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "required": [
            "kind"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "any"
            },
            "predicates": {
              "minItems": 1,
              "type": "array",
              "items": {
                "$ref": "#/$defs/UntilPredicate"
              }
            }
          },
          "required": [
            "kind",
            "predicates"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "all"
            },
            "predicates": {
              "minItems": 1,
              "type": "array",
              "items": {
                "$ref": "#/$defs/UntilPredicate"
              }
            }
          },
          "required": [
            "kind",
            "predicates"
          ],
          "additionalProperties": false
        }
      ],
      "title": "UntilPredicate"
    }
  }
}
