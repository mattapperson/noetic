{
  "name": "@noetic/core",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./portable": {
      "types": "./src/portable.ts",
      "default": "./src/portable.ts"
    },
    "./unstable": {
      "types": "./src/unstable.ts",
      "default": "./src/unstable.ts"
    },
    "./internal/test": {
      "types": "./src/internal-test.ts",
      "default": "./src/internal-test.ts"
    }
  },
  "devDependencies": {
    "@openrouter/agent": "0.3.1",
    "bun-types": "latest"
  },
  "peerDependencies": {
    "@openrouter/agent": "0.3.1",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@openrouter/agent": {
      "optional": true
    }
  },
  "dependencies": {
    "@openrouter/agent": "0.3.1",
    "zod": "^4.0.0"
  },
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=json",
    "test:ci": "bun test --coverage --coverage-reporter=json",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --fix .",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format ."
  }
}
