{
  "name": "@noetic-tools/core",
  "version": "1.1.2",
  "type": "module",
  "description": "Step primitives, interpreter, runtime, and memory layer contract for Noetic agents.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattapperson/noetic.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/mattapperson/noetic#readme",
  "bugs": {
    "url": "https://github.com/mattapperson/noetic/issues"
  },
  "keywords": [
    "noetic",
    "agents",
    "llm",
    "ai",
    "openrouter",
    "agent-framework"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./portable": {
      "bun": "./src/portable.ts",
      "types": "./dist/portable.d.ts",
      "default": "./dist/portable.js"
    },
    "./unstable": {
      "bun": "./src/unstable.ts",
      "types": "./dist/unstable.d.ts",
      "default": "./dist/unstable.js"
    },
    "./internal/test": {
      "bun": "./src/internal-test.ts",
      "types": "./dist/internal-test.d.ts",
      "default": "./dist/internal-test.js"
    },
    "./schema": "./schema/noetic-workflow.schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@openrouter/agent": "^0.6.0",
    "bun-types": "latest"
  },
  "peerDependencies": {
    "@openrouter/agent": "^0.6.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@openrouter/agent": {
      "optional": true
    }
  },
  "dependencies": {
    "@noetic-tools/memory": "workspace:*",
    "@noetic-tools/types": "workspace:*",
    "@openrouter/agent": "^0.6.0",
    "zod": "^4.0.0"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.build.json && bun scripts/add-js-extensions.ts",
    "gen:schema": "bun scripts/generate-workflow-schema.ts",
    "verify:esm": "bun scripts/verify-node-esm.ts",
    "prepublishOnly": "rm -rf dist && bun run gen:schema && bun run build && bun run verify:esm && bun scripts/pin-workspace-deps.ts && bun scripts/strip-dev-conditions.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "test:ci": "bun test --coverage --coverage-reporter=lcov",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --fix .",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format ."
  }
}
