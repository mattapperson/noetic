{
  "name": "@noetic-tools/core",
  "version": "0.0.1",
  "type": "module",
  "description": "Step primitives, interpreter, runtime, and memory layer contract for Noetic agents.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattapperson/noetic.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/mattapperson/noetic#readme",
  "bugs": {
    "url": "https://github.com/mattapperson/noetic/issues"
  },
  "keywords": [
    "noetic",
    "agents",
    "llm",
    "ai",
    "openrouter",
    "agent-framework"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./portable": {
      "types": "./dist/portable.d.ts",
      "default": "./dist/portable.js"
    },
    "./unstable": {
      "types": "./dist/unstable.d.ts",
      "default": "./dist/unstable.js"
    },
    "./internal/test": {
      "types": "./dist/internal-test.d.ts",
      "default": "./dist/internal-test.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@openrouter/agent": "^0.6.0",
    "bun-types": "latest"
  },
  "peerDependencies": {
    "@openrouter/agent": "^0.6.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@openrouter/agent": {
      "optional": true
    }
  },
  "dependencies": {
    "@openrouter/agent": "^0.6.0",
    "zod": "^4.0.0"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.build.json",
    "prepublishOnly": "rm -rf dist && bun run build",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=json",
    "test:ci": "bun test --coverage --coverage-reporter=json",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --fix .",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format ."
  }
}
