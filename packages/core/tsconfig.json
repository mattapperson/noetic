{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "paths": {
      "@noetic-tools/types": ["../types/src/index.ts"],
      "@noetic-tools/types/contract": ["../types/src/types/memory.ts"],
      "@noetic-tools/memory": ["../memory/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
