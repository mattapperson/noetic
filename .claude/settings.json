{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/biome-check.sh",
            "timeout": 30,
            "statusMessage": "Running biome auto-fix & check..."
          }
        ]
      }
    ]
  }
}
