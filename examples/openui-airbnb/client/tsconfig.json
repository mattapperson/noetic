{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "@openui/parser": ["../../../packages/openui/src/lang/parser.ts"],
      "@openui/document": ["../../../packages/openui/src/lang/document.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
