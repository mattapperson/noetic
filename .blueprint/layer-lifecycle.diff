+
+export async function recallLayersAtomic(params: RecallLayersParams): Promise<
+  {
+    layerId: string;
+    items: Item[];
+    tokenCount: number;
+  }[]
+> {
+  const atomicLayers = params.layers.filter((l) => l.recallMode !== 'eventual');
